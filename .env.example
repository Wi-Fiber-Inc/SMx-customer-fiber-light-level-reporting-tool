# SMx Northbound API. Keep /rest/v1 in the base URL.
SMX_BASE_URL=https://10.100.100.220:18443/rest/v1

# Use a dedicated read-only SMx account when possible.
SMX_USERNAME=
SMX_PASSWORD=

# Set this to true only if SMx uses a self-signed certificate. This setting is
# applied only to requests made by this tool; it does not disable TLS checks
# for Node.js globally.
SMX_ALLOW_SELF_SIGNED_CERT=false

# Leave this at 2 for a current certificate. Try 1 if SMx reports that its
# certificate key is too weak. Replace the SMx certificate when possible.
SMX_TLS_SECURITY_LEVEL=2

# Time allowed for one SMx request before it is cancelled.
SMX_REQUEST_TIMEOUT_MS=10000

# Run a full collection every 15 minutes and stay under the SMx API guidance.
SMX_COLLECTION_INTERVAL_MINUTES=15
SMX_COLLECTION_RATE_PER_MINUTE=240

# Keep the report local unless it is placed behind proper network access control.
WEB_HOST=127.0.0.1
WEB_PORT=3000
